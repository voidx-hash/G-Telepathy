# Environment Variables — G Telepathy
# Copy this file to .env and fill in your values
# On the GCP VM: lives at /opt/gtelepath/.env (chmod 600)

# ─── Cloudflare D1 Database ────────────────────────────────────────────────────
# Get these from: dash.cloudflare.com → Workers & Pages → D1
# 1. Create a D1 database named "gtelepath"
# 2. Run the schema: d1/schema.sql in the D1 Console
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_D1_DATABASE_ID=your-d1-database-id
# API Token: dash.cloudflare.com → My Profile → API Tokens
# Required permissions: D1:Edit on your account
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# ─── Google Cloud ────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key
GOOGLE_SPEECH_API_KEY=your-google-speech-api-key
# Or use Application Default Credentials (recommended on GCP VM):
# GOOGLE_APPLICATION_CREDENTIALS=/opt/gtelepath/service-account.json

# ─── Voice Cloning ────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ─── JWT Auth (self-managed, no external auth service) ────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Backend ──────────────────────────────────────────────────────────────────
ENVIRONMENT=production
BACKEND_PORT=8000
# Comma-separated — no wildcards allowed in production
CORS_ORIGINS=https://your-frontend.vercel.app,https://yourdomain.com

# ─── GCP VM (informational — used in startup/deploy scripts) ──────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_VM_NAME=gtelepath-vm
GCP_VM_ZONE=us-central1-a
GCP_VM_HOST=your-vm-external-ip-or-domain.com

# ─── Frontend Next.js ─────────────────────────────────────────────────────────
# Set in Vercel environment variables, not in this file
NEXT_PUBLIC_BACKEND_URL=https://your-vm-domain-or-ip.com
NEXT_PUBLIC_APP_NAME=G Telepathy
