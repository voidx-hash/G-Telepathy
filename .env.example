# Environment Variables — G Telepathy
# Copy this file to .env and fill in your values
# On the GCP VM, this lives at: /opt/gtelepath/.env (chmod 600)

# ─── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Google Cloud ────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key
GOOGLE_SPEECH_API_KEY=your-google-speech-api-key
# Recommended on GCP VM: use a Service Account + Application Default Credentials
# instead of API keys. Set this to the path of your service account JSON:
# GOOGLE_APPLICATION_CREDENTIALS=/opt/gtelepath/service-account.json

# ─── Voice Cloning ────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ─── JWT / Auth ───────────────────────────────────────────────────────────────
# Generate a strong secret: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Backend ──────────────────────────────────────────────────────────────────
# Set to "production" on the GCP VM to enable all security guards
ENVIRONMENT=production
BACKEND_PORT=8000

# Comma-separated list of allowed origins (your frontend URL/s)
# On GCP: use your Vercel URL or custom domain — never use *
CORS_ORIGINS=https://your-frontend.vercel.app,https://yourdomain.com

# ─── GCP VM specific ─────────────────────────────────────────────────────────
# These are informational — used in startup.sh and deploy.sh
GCP_PROJECT_ID=your-gcp-project-id
GCP_VM_NAME=gtelepath-vm
GCP_VM_ZONE=us-central1-a
# Your VM's external IP or custom domain pointing to it
GCP_VM_HOST=your-vm-external-ip-or-domain.com

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
# Set these in Vercel environment variables (not in this file)
NEXT_PUBLIC_BACKEND_URL=https://your-vm-external-ip-or-domain.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_NAME=G Telepathy
